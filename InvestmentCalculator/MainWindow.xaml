<Window x:Class="InvestmentCalculator.MainWindow"
        xmlns:Wpf="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InvestmentCalculator"
        xmlns:viewModels="clr-namespace:InvestmentCalculator.ViewModels"
        Title="Инвестиционный калькулятор" 
        Height="500" Width="600" 
        WindowStartupLocation="CenterScreen"
        FontSize="14">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Для кнопок -->
            <RowDefinition Height="*"/>
            <!-- Для графика -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Инвестиционный калькулятор" FontSize="20" FontWeight="Bold" Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="5"/>

        <!-- Строка 1: Начальная сумма -->
        <TextBlock Text="Начальная сумма (₽):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox Text="{Binding InitialAmount, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="5" Padding="3"/>

        <!-- Строка 2: Ежемесячный взнос -->
        <TextBlock Text="Ежемесячный взнос (₽):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox Text="{Binding MonthlyContribution, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="5" Padding="3"/>

        <!-- Строка 3: Годовая ставка -->
        <TextBlock Text="Годовая ставка (%):" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox Text="{Binding InterestRate, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="5" Padding="3"/>

        <!-- Строка 4: Срок (лет) -->
        <TextBlock Text="Срок (лет):" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox Text="{Binding Years, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="5" Padding="3"  />

        <!-- Строка 5: Кнопки -->
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Рассчитать" Command="{Binding CalculateCommand}" Width="100" Height="35" Margin="5"/>
            <Button Content="Сохранить расчёт" Command="{Binding SaveAsyncCommand}" Width="120" Height="35" Margin="5"/>
            <Button Content="История" Command="{Binding OpenHistoryCommand}" Width="100" Height="35" Margin="5"/>
        </StackPanel>

        <!-- Строка 6: Результаты и график -->
        <Grid Grid.Row="6" Grid.ColumnSpan="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Результаты -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,5">
                <StackPanel>
                    <TextBlock Text="РЕЗУЛЬТАТЫ" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding FutureValue, StringFormat='Будущая стоимость: {0:F2} ₽'}" Margin="0,2"/>
                    <TextBlock Text="{Binding TotalInvested, StringFormat='Общая сумма вложений: {0:F2} ₽'}" Margin="0,2"/>
                    <TextBlock Text="{Binding TotalInterest, StringFormat='Начисленные проценты: {0:F2} ₽'}" Margin="0,2"/>
                </StackPanel>
            </Border>

            <!-- График (занимает всю оставшуюся высоту) -->
            <Wpf:WpfPlot x:Name="InvestmentPlot" Grid.Row="1" Margin="0,5,0,0"/>

        </Grid>
    </Grid>
</Window>