<Window x:Class="InvestmentCalculator.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:InvestmentCalculator.ViewModels"
        Title="История расчётов" 
        Height="450" Width="800"
        WindowStartupLocation="CenterOwner"
        FontSize="14">

    <!-- DataContext будет установлен в коде или при открытии -->

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопка обновления -->
        <Button Content="Обновить" Command="{Binding RefreshAsyncCommand}" HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,5" Grid.Row="0"/>

        <!-- DataGrid для отображения истории -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Calculations}" 
                  SelectedItem="{Binding SelectedCalculation}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  Margin="0,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CalculationDate, StringFormat=dd.MM.yyyy HH:mm}" Width="120"/>
                <DataGridTextColumn Header="Нач. сумма" Binding="{Binding InitialAmount, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Взнос/мес" Binding="{Binding MonthlyContribution, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Ставка %" Binding="{Binding InterestRate, StringFormat=G}" Width="70"/>
                <DataGridTextColumn Header="Лет" Binding="{Binding Years}" Width="50"/>
                <DataGridTextColumn Header="Будущая ст-ть" Binding="{Binding FutureValue, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Прибыль" Binding="{Binding TotalInterest, StringFormat=N2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель с кнопками управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="Удалить выбранное" Command="{Binding DeleteAsyncCommand}" Width="150" Height="35" Margin="5"/>
            <Button Content="Закрыть" IsCancel="True" Width="100" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
